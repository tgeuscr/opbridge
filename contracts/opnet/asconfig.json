{
  "targets": {
    "bridge": {
      "outFile": "build/OpBridgeBridge.wasm",
      "use": ["abort=src/bridge/index/abort"]
    },
    "opusdt": {
      "outFile": "build/opUSDT.wasm",
      "use": ["abort=src/wrapped/opusdt/index/abort"]
    },
    "opwbtc": {
      "outFile": "build/opWBTC.wasm",
      "use": ["abort=src/wrapped/opwbtc/index/abort"]
    },
    "opweth": {
      "outFile": "build/opWETH.wasm",
      "use": ["abort=src/wrapped/opweth/index/abort"]
    },
    "oppaxg": {
      "outFile": "build/opPAXG.wasm",
      "use": ["abort=src/wrapped/oppaxg/index/abort"]
    }
  },
  "options": {
    "sourceMap": false,
    "optimizeLevel": 3,
    "shrinkLevel": 1,
    "converge": true,
    "noAssert": false,
    "runtime": "stub",
    "memoryBase": 0,
    "initialMemory": 1,
    "exportStart": "start",
    "transform": "@btc-vision/opnet-transform"
  }
}
