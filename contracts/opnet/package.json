{
  "name": "@opbridge/opnet-contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "npm run build:bridge && npm run build:opusdt && npm run build:opwbtc && npm run build:opweth && npm run build:oppaxg",
    "build:bridge": "asc src/bridge/index.ts --config asconfig.json --target bridge --measure --uncheckedBehavior never",
    "build:opusdt": "asc src/wrapped/opusdt/index.ts --config asconfig.json --target opusdt --measure --uncheckedBehavior never",
    "build:opwbtc": "asc src/wrapped/opwbtc/index.ts --config asconfig.json --target opwbtc --measure --uncheckedBehavior never",
    "build:opweth": "asc src/wrapped/opweth/index.ts --config asconfig.json --target opweth --measure --uncheckedBehavior never",
    "build:oppaxg": "asc src/wrapped/oppaxg/index.ts --config asconfig.json --target oppaxg --measure --uncheckedBehavior never",
    "test": "node tests/bridge-invariants.test.mjs",
    "typecheck": "echo 'TODO: add OP_NET-compatible type/lint checks'"
  },
  "dependencies": {
    "@assemblyscript/loader": "^0.28.9",
    "@btc-vision/as-bignum": "^0.1.2",
    "@btc-vision/assemblyscript": "^0.29.2",
    "@btc-vision/btc-runtime": "^1.11.0-rc.9",
    "@btc-vision/opnet-transform": "^1.2.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.2.3"
  }
}
