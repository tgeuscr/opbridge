# Production relayer instance template
# Copy to the instance-specific env file used by systemd and fill in values.

RELAYER_ID=relayer-mainnet-a
RELAYER_INDEX=0

# Prefer AWS Secrets Manager on EC2. Example secret JSON:
# {"relayPrivateKeys":["0x..."],"relayEvmPrivateKeys":["0x..."]}
RELAYER_KEYS_SECRET_REF=aws-sm://heptad/mainnet/relayer-a
RELAYER_EVM_KEYS_SECRET_REF=aws-sm://heptad/mainnet/relayer-a#relayEvmPrivateKeys

# Optional direct single-key refs:
# RELAYER_PRIVATE_KEY_SECRET_REF=aws-sm://heptad/mainnet/relayer-a#relayPrivateKeys.0
# RELAYER_EVM_PRIVATE_KEY_SECRET_REF=aws-sm://heptad/mainnet/relayer-a#relayEvmPrivateKeys.0

RELAYER_OUTPUT_FILE=/home/ssm-user/heptad/services/relayer/.data/attestations/relayer-mainnet-a.json
