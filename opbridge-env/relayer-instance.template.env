# Production relayer instance template
# Copy to the instance-specific env file used by systemd and fill in values.

RELAYER_ID=relayer-mainnet-a
RELAYER_INDEX=0

RELAYER_SIGNER_MODE=kms
RELAYER_KMS_KEY_ID=arn:aws:kms:us-east-2:123456789012:key/<mldsa-key-id>
RELAYER_EVM_SIGNER_MODE=kms
RELAYER_EVM_KMS_KEY_ID=arn:aws:kms:us-east-2:123456789012:key/<ecdsa-key-id>

RELAYER_OUTPUT_FILE=/home/ssm-user/opbridge/services/relayer/.data/attestations/relayer-mainnet-a.json
